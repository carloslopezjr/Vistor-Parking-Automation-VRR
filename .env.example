# Server Configuration
PORT=8080
BASE_URL=http://localhost:8080

# CSV Configuration
VEHICLES_CSV_PATH=./vehicles.csv

# Playwright Configuration
PLAYWRIGHT_TARGET_URL=https://app.vrrparking.com/visitors
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT=120s
PLAYWRIGHT_WAIT_AFTER_SUBMIT=5s

# Playwright Form Field Selectors (CSS selectors or XPath)
# Inspect the vrrparking.com form and set these to match the form field IDs or names
PLAYWRIGHT_SELECTOR_APARTMENT_NAME="input[placeholder=\"Enter Apartment Name\"]"
PLAYWRIGHT_SELECTOR_APARTMENT_CONFIRM_BUTTON="#apartmentConfirmButton"
PLAYWRIGHT_SELECTOR_LICENSE_PLATE="#licensePlate"
PLAYWRIGHT_SELECTOR_CONFIRMED_LICENSE_PLATE="#confirmedLicensePlate"
PLAYWRIGHT_SELECTOR_VEHICLE_MAKE="#vehicleMake"
PLAYWRIGHT_SELECTOR_VEHICLE_MODEL="#vehicleModel"
PLAYWRIGHT_SELECTOR_RESIDENT_NAME="#residentName"
PLAYWRIGHT_SELECTOR_UNIT_NUMBER="#unitNumber"
PLAYWRIGHT_SELECTOR_VISITOR_NAME="#visitorName"
PLAYWRIGHT_SELECTOR_RESIDENT_EMAIL="#confirmationEmail"
PLAYWRIGHT_SELECTOR_SUBMIT_BUTTON="#submitButton"
PLAYWRIGHT_SELECTOR_SUCCESS="#successMessage"

# Optional: Basic Auth (leave empty to disable)
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASS=password123
