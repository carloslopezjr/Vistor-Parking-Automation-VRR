# Example environment configuration for Visitor Parking Automation
# Copy this file to `.env.local` (or `.env`) and fill in real values.

PORT=8080
DATABASE_PATH=/Users/carlos/Desktop/Vistor-Parking-Automation-VRR/db/app.db #./data/app.db
BASE_URL=https://your-domain.example

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=noreply@example.com

SITE_TARGET_URL=https://app.vrrparking.com/visitors
PLAYWRIGHT_HEADLESS=true

# Optional basic auth for the web UI
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me
